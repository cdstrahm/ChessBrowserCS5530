    <ItemGroup>
        <Using Include="Xunit"/>
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\ChessBrowser\ChessBrowser.csproj" />
    </ItemGroup>

    <ItemGroup>
      <None Remove="TestData\kb1.pgn" />
